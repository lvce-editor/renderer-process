{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreIssues": {
    "packages/memory/src/config.ts": ["exports"]
  },
  "workspaces": {
    ".": {
      "project": ["*.js"],
      "ignoreDependencies": ["@lerna/legacy-package-management"]
    },
    "packages/build": {
      "project": ["src/**/*.js"],
      "ignoreDependencies": ["@lvce-editor/verror", "esbuild"]
    },
    "packages/e2e": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/memory": {
      "entry": ["src/measureMemory.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/renderer-process": {
      "entry": ["src/rendererProcessMain.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"],
      "ignoreFiles": ["src/parts/**"],
      "ignoreIssues": {
        "src/parts/**": ["duplicates", "exports", "types"]
      }
    },
    "packages/server": {
      "entry": ["src/postinstall.js"],
      "project": ["src/**/*.js"],
      "ignoreDependencies": ["@lvce-editor/server"]
    }
  }
}
